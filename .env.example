# =============================================
# ConfirmaID - Environment Variables Template
# =============================================
# Copie este arquivo para .env (desenvolvimento local) ou .env.production
# NUNCA commite arquivos .env reais

# ---------------------------------------------
# Aplicação / Next.js
# ---------------------------------------------
NODE_ENV=development
# Porta interna da aplicação (dentro do Docker geralmente 3000)
PORT=3000

# URL pública da aplicação (usada pelo Auth.js e links)
NEXT_PUBLIC_APP_URL=https://confirmaid.com.br

# ---------------------------------------------
# Banco de Dados (PostgreSQL)
# ---------------------------------------------
DATABASE_URL="postgresql://confirmaid:CHANGE_ME@db:5432/confirmaid?schema=public"

# Credenciais do banco (usadas no docker-compose)
POSTGRES_USER=confirmaid
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=confirmaid

# ---------------------------------------------
# Autenticação (Auth.js / NextAuth v5)
# ---------------------------------------------
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_32_BYTES_OR_MORE

# Deve bater com NEXT_PUBLIC_APP_URL
NEXTAUTH_URL=https://confirmaid.com.br

# ---------------------------------------------
# Armazenamento Seguro de Arquivos (CRÍTICO)
# ---------------------------------------------
# Chave de criptografia AES-256-GCM (EXATAMENTE 32 bytes / 64 caracteres hex)
# Gere com: openssl rand -hex 32
STORAGE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Diretório onde os arquivos criptografados serão salvos (dentro do container)
STORAGE_PATH=/app/storage/private

# Tamanho máximo permitido por upload em bytes (ex: 8MB = 8388608)
MAX_UPLOAD_SIZE_BYTES=8388608

# ---------------------------------------------
# Configurações de Segurança / Operação
# ---------------------------------------------
# Tempo de expiração da verificação em meses (MVP = 12)
VERIFICATION_EXPIRATION_MONTHS=12

# SLA interno de análise em horas úteis (apenas informativo)
ANALYSIS_SLA_HOURS=24

# ---------------------------------------------
# Email (futuro / placeholder para MVP)
# ---------------------------------------------
# SMTP ou serviço de email (Resend, SendGrid, etc.)
# EMAIL_SERVER=smtp://...
# EMAIL_FROM=noreply@confirmaid.com.br

# ---------------------------------------------
# Cloudflare / Tunnel (informativo - não usado diretamente pela app)
# ---------------------------------------------
# O tunnel é configurado no VPS via cloudflared.
# Estas variáveis são apenas documentação.
# CLOUDFLARE_TUNNEL_TOKEN=...

# ---------------------------------------------
# Logs e Monitoramento (básico)
# ---------------------------------------------
LOG_LEVEL=info

# =============================================
# INSTRUÇÕES DE GERAÇÃO DE SECRETS
# =============================================
#
# 1. STORAGE_ENCRYPTION_KEY:
#    openssl rand -hex 32
#
# 2. NEXTAUTH_SECRET:
#    openssl rand -base64 32
#
# 3. POSTGRES_PASSWORD:
#    Gere uma senha forte (mínimo 20 caracteres, misture letras, números e símbolos).
#
# Guarde TODAS as secrets em um gerenciador de senhas (Bitwarden, 1Password, etc.)
# e faça backup offline seguro.
#
# Nunca use as mesmas secrets entre ambiente de desenvolvimento e produção.
# =============================================