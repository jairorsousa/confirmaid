generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Initial models based on data-model.md for MVP
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  cpf           String   @unique
  birthDate     DateTime
  phone         String?
  passwordHash  String
  role          UserRole @default(USER)
  status        UserStatus @default(ACTIVE)
  partnerId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  verifications Verification[]
  reviewedVerifications Verification[] @relation("Reviewer")
  consultations Consultation[] @relation("ConsultedUser")
  auditLogs     AuditLog[]
}

enum UserRole {
  USER
  PARTNER
  ANALYST
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model Verification {
  id                String              @id @default(cuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id])
  documentType      DocumentType
  status            VerificationStatus  @default(PENDING)
  code              String?             @unique
  submittedAt       DateTime?
  reviewedAt        DateTime?
  expiresAt         DateTime?
  reviewedById      String?
  reviewer          User?               @relation("Reviewer", fields: [reviewedById], references: [id])
  rejectionReason   String?
  correctionReason  String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  documents         Document[]
  consultations     Consultation[]
  history           VerificationHistory[]
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  CORRECTION_REQUESTED
  APPROVED
  REJECTED
  BLOCKED
  EXPIRED
  ABANDONED
}

enum DocumentType {
  RG
  CNH
}

model Document {
  id                   String   @id @default(cuid())
  verificationId       String
  verification         Verification @relation(fields: [verificationId], references: [id])
  type                 DocumentType
  storedFilename       String
  originalFilenameHash String?
  mimeType             String
  sizeBytes            Int
  sha256               String
  iv                   String
  authTag              String
  uploadedAt           DateTime @default(now())
}

model Partner {
  id            String        @id @default(cuid())
  legalName     String
  tradeName     String?
  cnpj          String        @unique
  contactName   String
  contactEmail  String
  contactPhone  String?
  status        PartnerStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  consultations Consultation[]
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

model Consultation {
  id                String   @id @default(cuid())
  partnerId         String
  partner           Partner  @relation(fields: [partnerId], references: [id])
  userId            String?
  user              User?    @relation("ConsultedUser", fields: [userId], references: [id])
  verificationId    String?
  verification      Verification? @relation(fields: [verificationId], references: [id])
  queryType         String   // "code" | "email" | "cpf"
  queryValueHash    String?
  resultStatus      String
  createdAt         DateTime @default(now())
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  actor         User?    @relation(fields: [actorUserId], references: [id])
  action        String
  entityType    String
  entityId      String
  details       Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())
}

model VerificationHistory {
  id             String   @id @default(cuid())
  verificationId String
  verification   Verification @relation(fields: [verificationId], references: [id])
  previousStatus String?
  newStatus      String
  changedById    String?
  reason         String?
  createdAt      DateTime @default(now())
}
